# SAYAN BOT — Variables de entorno
# Copia como .env y rellena con tus datos

# Telegram (de @BotFather)
TELEGRAM_BOT_TOKEN=tu_token_aqui
OWNER_ID=tu_telegram_id_numerico

# LLM (OpenRouter — https://openrouter.ai)
OPENROUTER_API_KEY=tu_key_openrouter

# Modelo (Hermes 4 gratis por defecto)
LLM_MODEL=nousresearch/hermes-4-scout
LLM_FALLBACK=deepseek/deepseek-chat-v3-0324:free

# Puerto para health check (Render)
PORT=8080
